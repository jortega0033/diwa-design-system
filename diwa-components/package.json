{
  "name": "@diwacopilot/components",
  "version": "1.1.0",
  "description": "Diwa Design System - Framework-agnostic Web Components built with Stencil.js",
  "license": "MIT",
  "homepage": "https://diwacopilot.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jortega0033/diwa-design-system.git",
    "directory": "diwa-components"
  },
  "bugs": {
    "url": "https://github.com/jortega0033/diwa-design-system/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "loader/",
    "dist-custom-elements/"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    },
    "./loader": {
      "import": "./loader/index.js"
    },
    "./dist-custom-elements": {
      "import": "./dist-custom-elements/index.js"
    },
    "./styles": {
      "import": "./dist/styles/index.js"
    }
  },
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "browser": "dist/diwa-components/diwa-components.esm.js",
  "scripts": {
    "patch:stencil": "node scripts/patch-stencil-event-warnings.js",
    "prebuild": "npm run patch:stencil",
    "build": "stencil build",
    "build.watch": "stencil build --watch",
    "dev:stencil": "npm run patch:stencil && stencil build --watch --serve",
    "predev": "node -e \"const fs=require('fs'),p=require('path').join(__dirname,'storefront','public','stencil');if(fs.existsSync(p)){fs.rmSync(p,{recursive:true});console.log('[predev] Cleared storefront/public/stencil/ so dev proxy works')}\"",
    "dev": "concurrently -n \"stencil,storefront\" -c \"blue,green\" \"npm run dev:stencil\" \"npm --prefix storefront run dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ux": "vitest run src/utils/styles.spec.ts src/global/app.spec.ts tests/unit/ux/wave1-interaction-contract.spec.ts",
    "ux:design-system": "python .codex/skills/ui-ux-pro-max/scripts/search.py \"component library design system developer documentation accessibility\" --design-system --persist -f markdown -p \"Diwa Design System\"",
    "generate": "stencil generate"
  },
  "dependencies": {
    "@stencil/core": "~4.23.2",
    "lucide": "^0.577.0"
  },
  "devDependencies": {
    "@stencil/angular-output-target": "^0.9.0",
    "@stencil/react-output-target": "^0.5.3",
    "@stencil/vue-output-target": "^0.8.8",
    "@types/jest": "^29.5.14",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jsdom": "^29.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
